# Discord OAuth (reuse same app as main site, add editor redirect URI)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Auth
AUTH_SECRET=          # Random 32+ char string (different from main app)
EDITOR_URL=https://editor.jacobmaynard.dev  # or http://localhost:4200 for dev

# Cloudflare D1
CF_ACCOUNT_ID=        # Cloudflare account ID
CF_D1_DATABASE_ID=    # Production D1 database ID
CF_API_TOKEN=         # API token with D1:edit permission

# Cloudflare R2 (S3-compatible credentials from R2 settings)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=paleo-waifu-images-prod

# Server
PORT=4100
NODE_ENV=development
