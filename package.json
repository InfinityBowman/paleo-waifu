{
  "name": "paleo-waifu",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "concurrently -n app,editor -c blue,green \"vite dev --port 3000\" \"pnpm editor\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "CLOUDFLARE_ENV=production vite build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply paleo-waifu-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply paleo-waifu-db-prod --remote --env production",
    "clear:data:local": "rm -rf .wrangler/state && pnpm run db:migrate:local",
    "db:seed:dev-users": "wrangler d1 execute paleo-waifu-db --local --file=./seed-dev-users.sql",
    "db:seed:battle:local": "wrangler d1 execute paleo-waifu-db --local --file=./battle_seed.sql",
    "db:seed:battle:prod": "wrangler d1 execute paleo-waifu-db-prod --remote --env production --file=./battle_seed.sql",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "typecheck": "tsc --noEmit",
    "bot:dev": "cd bot && pnpm dev",
    "bot:deploy": "cd bot && pnpm deploy:prod",
    "bot:register": "cd bot && pnpm register",
    "bot:register:prod": "cd bot && pnpm register:prod",
    "bot:typecheck": "cd bot && pnpm typecheck",
    "gateway:dev": "cd gateway && pnpm dev",
    "gateway:build": "cd gateway && pnpm build",
    "gateway:typecheck": "cd gateway && pnpm typecheck",
    "editor": "cd editor && pnpm dev",
    "sim": "cd tools/battle-sim && pnpm sim",
    "sim:matchup": "cd tools/battle-sim && pnpm sim:matchup",
    "sim:team": "cd tools/battle-sim && pnpm sim:team",
    "sim:role": "cd tools/battle-sim && pnpm sim:role",
    "sim:creature": "cd tools/battle-sim && pnpm sim:creature",
    "sim:ability": "cd tools/battle-sim && pnpm sim:ability",
    "sim:csv": "cd tools/battle-sim && pnpm sim:csv",
    "sim:typecheck": "cd tools/battle-sim && pnpm typecheck",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'tests/production/**'",
    "test:watch": "vitest",
    "deps:up": "pnpm update --latest --recursive"
  },
  "dependencies": {
    "@paleo-waifu/shared": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-start": "^1.166.1",
    "better-auth": "^1.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.4",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.6",
    "@cloudflare/workers-types": "^4.20260301.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/router-plugin": "^1.164.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "workerd"
    ]
  }
}
