# Discord bot token (same as the bot Worker)
# The bot must have the Message Content Intent enabled in the Developer Portal
DISCORD_BOT_TOKEN=

# Full URL to the XP endpoint on the bot Worker
# Example: https://paleo-waifu-bot.your-subdomain.workers.dev/api/xp
XP_API_URL=

# Shared secret for authenticating XP API requests
# Must match XP_API_SECRET on the bot Worker
# Generate with: openssl rand -base64 32
XP_API_SECRET=
