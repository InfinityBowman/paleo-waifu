{
  "name": "@paleo-waifu/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "CLOUDFLARE_ENV=production vite build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply paleo-waifu-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply paleo-waifu-db-prod --remote --env production",
    "clear:data:local": "rm -rf .wrangler/state && pnpm run db:migrate:local",
    "db:seed:dev-users": "wrangler d1 execute paleo-waifu-db --local --file=./seed-dev-users.sql",
    "db:seed:battle:local": "wrangler d1 execute paleo-waifu-db --local --file=./battle_seed.sql",
    "db:seed:battle:prod": "wrangler d1 execute paleo-waifu-db-prod --remote --env production --file=./battle_seed.sql",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'tests/production/**'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@paleo-waifu/shared": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-start": "^1.166.1",
    "better-auth": "^1.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.4",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.6",
    "@cloudflare/workers-types": "^4.20260301.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/router-plugin": "^1.164.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
