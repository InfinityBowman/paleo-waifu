{
  "name": "paleo-waifu-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c wrangler.jsonc",
    "deploy": "wrangler deploy -c wrangler.jsonc",
    "deploy:prod": "wrangler deploy -c wrangler.jsonc --env production",
    "register": "node --env-file=.env --import=tsx/esm register.ts",
    "register:prod": "node --env-file=.env --import=tsx/esm register.ts --prod",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts"
  },
  "dependencies": {
    "@paleo-waifu/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@noble/ed25519": "^3.0.0",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
