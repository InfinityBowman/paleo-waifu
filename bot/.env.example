# Discord application credentials
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# For dev: register commands to a specific guild (instant updates)
DISCORD_DEV_GUILD_ID=
DISCORD_BOT_PROD_BASE_URL=

# Shared secret for the Gateway Listener's XP API calls
# Must match XP_API_SECRET in gateway/.env
# Generate with: openssl rand -base64 32
XP_API_SECRET=